<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %> · Elba Farm Management</title>
<script src="https://cdn.tailwindcss.com"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
<script>
  tailwind.config = {
    theme: {
      extend: {
        fontFamily: { display: ['Plus Jakarta Sans','sans-serif'], body: ['Inter','sans-serif'] },
        colors: {
          forest: { 50:'#f0f5f1', 100:'#dbe8de', 300:'#8fb89b', 500:'#3d7a55', 600:'#2c5c3f', 700:'#234a33', 800:'#1b3a28', 900:'#122a1c' },
          wheat: { 100:'#fbf1de', 300:'#eecd8f', 500:'#d9a441', 600:'#c08a2c' },
          clay: { 500:'#c1543a', 600:'#a8432c' }
        }
      }
    }
  }
</script>
<style>
  body { font-family: 'Inter', sans-serif; background:#f6f4ef; }
  .font-display { font-family: 'Plus Jakarta Sans', sans-serif; }
  ::-webkit-scrollbar { width: 8px; height:8px; }
  ::-webkit-scrollbar-thumb { background:#c9c3b3; border-radius:4px; }
</style>
</head>
<body class="text-forest-900">
<div class="flex min-h-screen">
  <!-- Sidebar -->
  <aside class="w-64 bg-forest-800 text-forest-100 flex-shrink-0 hidden md:flex flex-col">
    <div class="px-6 py-5 border-b border-forest-700/60">
      <div class="flex items-center gap-2">
        <div class="w-9 h-9 rounded-xl bg-wheat-500 flex items-center justify-center text-forest-900 font-display font-extrabold">EF</div>
        <div>
          <p class="font-display font-bold text-white leading-tight">Elba Farm</p>
          <p class="text-[11px] text-forest-300 tracking-wide">MANAGEMENT SYSTEM</p>
        </div>
      </div>
    </div>
    <nav class="flex-1 px-3 py-4 space-y-1 text-sm">
      <% const nav = [
        {href:'/', label:'Dashboard', icon:'📊'},
        {href:'/kandang', label:'Kandang', icon:'🏠'},
        {href:'/ayam', label:'Ayam / Batch', icon:'🐔'},
        {href:'/pakan', label:'Pakan', icon:'🌾'},
        {href:'/produksi', label:'Produksi Telur', icon:'🥚'},
        {href:'/penjualan', label:'Penjualan', icon:'💰'},
        {href:'/keuangan', label:'Keuangan', icon:'📒'}
      ]; %>
      <% nav.forEach(item => { %>
        <a href="<%= item.href %>"
           class="flex items-center gap-3 px-3 py-2.5 rounded-lg transition <%= currentPath === item.href ? 'bg-forest-600 text-white font-semibold' : 'text-forest-200 hover:bg-forest-700/70 hover:text-white' %>">
          <span class="text-base"><%= item.icon %></span>
          <span><%= item.label %></span>
        </a>
      <% }) %>
    </nav>
    <div class="px-4 py-4 border-t border-forest-700/60">
      <div class="flex items-center gap-3 px-2 py-2 rounded-lg bg-forest-700/50">
        <div class="w-8 h-8 rounded-full bg-wheat-500 flex items-center justify-center text-forest-900 text-xs font-bold">
          <%= currentUser ? currentUser.nama.charAt(0).toUpperCase() : '?' %>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-xs font-semibold text-white truncate"><%= currentUser ? currentUser.nama : '' %></p>
          <p class="text-[10px] text-forest-300 capitalize"><%= currentUser ? currentUser.role.replace('_',' ') : '' %></p>
        </div>
      </div>
      <form action="/logout" method="POST" class="mt-2">
        <button class="w-full text-xs text-forest-300 hover:text-white text-left px-2 py-1.5 rounded-lg hover:bg-forest-700/70 transition">↩ Keluar</button>
      </form>
    </div>
  </aside>

  <!-- Main -->
  <div class="flex-1 flex flex-col min-w-0">
    <header class="bg-white border-b border-black/5 px-4 md:px-8 py-4 flex items-center justify-between sticky top-0 z-10">
      <h1 class="font-display text-lg md:text-xl font-bold text-forest-900"><%= title %></h1>
      <div class="text-xs text-forest-500 font-medium hidden sm:block">
        <%= new Date().toLocaleDateString('id-ID', { weekday:'long', year:'numeric', month:'long', day:'numeric' }) %>
      </div>
    </header>
    <main class="flex-1 p-4 md:p-8">
      <%- body %>
    </main>
  </div>
</div>
</body>
</html>
