<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Masuk · Elba Farm Management</title>
<script src="https://cdn.tailwindcss.com"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<script>
  tailwind.config = { theme: { extend: {
    fontFamily: { display: ['Plus Jakarta Sans','sans-serif'], body: ['Inter','sans-serif'] },
    colors: { forest: { 500:'#3d7a55', 600:'#2c5c3f', 700:'#234a33', 800:'#1b3a28', 900:'#122a1c' }, wheat: { 400:'#e3b866', 500:'#d9a441' } }
  } } }
</script>
<style>body{font-family:'Inter',sans-serif;}.font-display{font-family:'Plus Jakarta Sans',sans-serif;}</style>
</head>
<body class="min-h-screen flex">
  <div class="hidden lg:flex w-1/2 bg-forest-800 relative overflow-hidden flex-col justify-between p-12 text-white">
    <div class="absolute inset-0 opacity-10" style="background-image:radial-gradient(circle at 20% 20%, white 1px, transparent 1px); background-size:24px 24px;"></div>
    <div class="relative z-10 flex items-center gap-3">
      <div class="w-10 h-10 rounded-xl bg-wheat-500 flex items-center justify-center text-forest-900 font-display font-extrabold">EF</div>
      <span class="font-display font-bold text-lg">Elba Farm Management</span>
    </div>
    <div class="relative z-10">
      <p class="text-5xl mb-4">🐔🥚</p>
      <h2 class="font-display text-3xl font-extrabold leading-tight mb-3">Kelola peternakan<br>Elba dalam satu sistem.</h2>
      <p class="text-forest-200 text-sm max-w-sm">Populasi, produksi telur, pakan, kesehatan, hingga keuangan — semua terpantau real-time di satu dashboard.</p>
    </div>
    <p class="relative z-10 text-xs text-forest-300">© <%= new Date().getFullYear() %> Elba Farm Management</p>
  </div>

  <div class="flex-1 flex items-center justify-center p-6 bg-[#f6f4ef]">
    <div class="w-full max-w-sm">
      <div class="lg:hidden flex items-center gap-3 mb-8 justify-center">
        <div class="w-10 h-10 rounded-xl bg-wheat-500 flex items-center justify-center text-forest-900 font-display font-extrabold">EF</div>
        <span class="font-display font-bold text-lg text-forest-900">Elba Farm</span>
      </div>
      <h1 class="font-display text-2xl font-bold text-forest-900 mb-1">Masuk ke akun</h1>
      <p class="text-sm text-forest-600/70 mb-6">Masukkan username dan password kamu.</p>

      <% if (error) { %>
        <div class="mb-4 px-4 py-2.5 rounded-lg bg-clay-50 text-clay-600 text-sm border border-red-200 bg-red-50 text-red-600"><%= error %></div>
      <% } %>

      <form action="/login" method="POST" class="space-y-4">
        <div>
          <label class="block text-xs font-semibold text-forest-700 mb-1">Username</label>
          <input name="username" required class="w-full px-4 py-2.5 rounded-lg border border-forest-200 focus:outline-none focus:ring-2 focus:ring-forest-500" placeholder="owner">
        </div>
        <div>
          <label class="block text-xs font-semibold text-forest-700 mb-1">Password</label>
          <input name="password" type="password" required class="w-full px-4 py-2.5 rounded-lg border border-forest-200 focus:outline-none focus:ring-2 focus:ring-forest-500" placeholder="••••••••">
        </div>
        <button class="w-full bg-forest-700 hover:bg-forest-800 text-white font-semibold py-2.5 rounded-lg transition">Masuk</button>
      </form>

      <div class="mt-6 text-xs text-forest-500 bg-white border border-forest-100 rounded-lg p-3">
        <p class="font-semibold mb-1">Akun demo:</p>
        <p>admin / admin123</p>
      </div>
    </div>
  </div>
</body>
</html>
