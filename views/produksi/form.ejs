<div class="max-w-lg bg-white rounded-2xl border border-black/5 shadow-sm p-6">
  <form action="/produksi" method="POST" class="space-y-4">
    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="block text-xs font-semibold text-forest-700 mb-1">Tanggal</label>
        <input name="tanggal" type="date" required value="<%= new Date().toISOString().slice(0,10) %>" class="w-full px-4 py-2.5 rounded-lg border border-forest-200 focus:outline-none focus:ring-2 focus:ring-forest-500">
      </div>
      <div>
        <label class="block text-xs font-semibold text-forest-700 mb-1">Batch</label>
        <select name="batch_id" required class="w-full px-4 py-2.5 rounded-lg border border-forest-200 focus:outline-none focus:ring-2 focus:ring-forest-500">
          <% batch.forEach(b => { %><option value="<%= b.id %>"><%= b.kode_batch %></option><% }) %>
        </select>
      </div>
    </div>
    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="block text-xs font-semibold text-forest-700 mb-1">Jumlah Telur (butir)</label>
        <input name="jumlah_butir" type="number" min="0" required class="w-full px-4 py-2.5 rounded-lg border border-forest-200 focus:outline-none focus:ring-2 focus:ring-forest-500">
      </div>
      <div>
        <label class="block text-xs font-semibold text-forest-700 mb-1">Berat Total (kg)</label>
        <input name="berat_kg" type="number" step="0.01" min="0" class="w-full px-4 py-2.5 rounded-lg border border-forest-200 focus:outline-none focus:ring-2 focus:ring-forest-500">
      </div>
    </div>
    <div class="grid grid-cols-3 gap-3">
      <div><label class="block text-xs font-semibold text-forest-700 mb-1">Grade A</label><input name="grade_a" type="number" min="0" value="0" class="w-full px-3 py-2 rounded-lg border border-forest-200"></div>
      <div><label class="block text-xs font-semibold text-forest-700 mb-1">Grade B</label><input name="grade_b" type="number" min="0" value="0" class="w-full px-3 py-2 rounded-lg border border-forest-200"></div>
      <div><label class="block text-xs font-semibold text-forest-700 mb-1">Grade C</label><input name="grade_c" type="number" min="0" value="0" class="w-full px-3 py-2 rounded-lg border border-forest-200"></div>
    </div>
    <div class="grid grid-cols-2 gap-4">
      <div><label class="block text-xs font-semibold text-forest-700 mb-1">Telur Retak</label><input name="retak" type="number" min="0" value="0" class="w-full px-4 py-2.5 rounded-lg border border-forest-200"></div>
      <div><label class="block text-xs font-semibold text-forest-700 mb-1">Telur Rusak</label><input name="rusak" type="number" min="0" value="0" class="w-full px-4 py-2.5 rounded-lg border border-forest-200"></div>
    </div>
    <div class="flex gap-3 pt-2">
      <button class="bg-forest-700 hover:bg-forest-800 text-white font-semibold px-5 py-2.5 rounded-lg transition text-sm">Simpan</button>
      <a href="/produksi" class="text-forest-500 text-sm font-semibold px-5 py-2.5">Batal</a>
    </div>
  </form>
</div>
