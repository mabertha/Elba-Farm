<div class="space-y-6">
  <div class="flex items-center justify-between">
    <a href="/ayam" class="text-sm text-forest-500 hover:text-forest-700 font-semibold">← Kembali ke daftar batch</a>
    <div class="flex gap-2">
      <a href="/ayam/<%= batch.id %>/edit" class="bg-white border border-forest-200 text-forest-700 text-sm font-semibold px-4 py-2 rounded-lg hover:bg-forest-50 transition">Edit Batch</a>
    </div>
  </div>

  <!-- Header -->
  <div class="bg-white rounded-2xl border border-black/5 shadow-sm p-6">
    <div class="flex flex-wrap items-start justify-between gap-4 mb-5">
      <div>
        <p class="font-display text-2xl font-extrabold text-forest-900"><%= batch.kode_batch %></p>
        <p class="text-sm text-forest-500"><%= batch.ras %> · Kandang <%= batch.kandang_nama %></p>
      </div>
      <span class="text-xs font-semibold px-3 py-1.5 rounded-full <%= batch.status_produksi === 'produktif' ? 'bg-forest-50 text-forest-600' : 'bg-wheat-100 text-wheat-600' %>">
        <%= batch.status_produksi %>
      </span>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-5 gap-4 text-center">
      <div class="bg-forest-50 rounded-xl p-3">
        <p class="text-[11px] text-forest-500 mb-1">Umur Sekarang</p>
        <p class="font-display font-extrabold text-forest-900"><%= batch.umur_minggu %> mgg</p>
        <p class="text-[10px] text-forest-400">(± <%= batch.umur_bulan %> bulan)</p>
      </div>
      <div class="bg-forest-50 rounded-xl p-3">
        <p class="text-[11px] text-forest-500 mb-1">Jumlah Aktif</p>
        <p class="font-display font-extrabold text-forest-900"><%= batch.jumlah_aktif %></p>
        <p class="text-[10px] text-forest-400">dari <%= batch.jumlah_awal %> ekor awal</p>
      </div>
      <div class="bg-red-50 rounded-xl p-3">
        <p class="text-[11px] text-forest-500 mb-1">Mati</p>
        <p class="font-display font-extrabold text-clay-600"><%= batch.jumlah_mati %></p>
      </div>
      <div class="bg-wheat-100 rounded-xl p-3">
        <p class="text-[11px] text-forest-500 mb-1">Afkir</p>
        <p class="font-display font-extrabold text-wheat-600"><%= batch.jumlah_afkir %></p>
      </div>
      <div class="bg-forest-50 rounded-xl p-3">
        <p class="text-[11px] text-forest-500 mb-1">Rata Telur/Catatan</p>
        <p class="font-display font-extrabold text-forest-900"><%= rataTelurPerHari %></p>
      </div>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-5 text-sm">
      <div><p class="text-forest-400 text-xs">Tanggal Masuk</p><p class="font-medium text-forest-800"><%= batch.tanggal_masuk %></p></div>
      <div><p class="text-forest-400 text-xs">Umur Saat Masuk</p><p class="font-medium text-forest-800"><%= batch.umur_awal_hari ? Math.round(batch.umur_awal_hari/7) + ' minggu' : 'Baru menetas (0 minggu)' %></p></div>
      <div><p class="text-forest-400 text-xs">Asal Supplier</p><p class="font-medium text-forest-800"><%= batch.asal_supplier || '-' %></p></div>
      <div><p class="text-forest-400 text-xs">Total Telur Tercatat</p><p class="font-medium text-forest-800"><%= totalTelur %> butir</p></div>
    </div>
    <% if (batch.catatan) { %>
      <div class="mt-4 pt-4 border-t border-forest-50">
        <p class="text-forest-400 text-xs mb-1">Catatan</p>
        <p class="text-sm text-forest-700"><%= batch.catatan %></p>
      </div>
    <% } %>
  </div>

  <!-- Riwayat Kesehatan -->
  <div class="bg-white rounded-2xl border border-black/5 shadow-sm overflow-hidden">
    <div class="px-5 py-3 border-b border-forest-50">
      <h3 class="font-display font-bold text-forest-900 text-sm">Riwayat Kesehatan (Kematian / Afkir)</h3>
    </div>
    <table class="w-full text-sm">
      <thead class="bg-forest-50 text-forest-600 text-xs uppercase">
        <tr><th class="text-left px-5 py-2">Tanggal</th><th class="text-left px-5 py-2">Jenis</th><th class="text-left px-5 py-2">Jumlah</th><th class="text-left px-5 py-2">Catatan</th></tr>
      </thead>
      <tbody class="divide-y divide-forest-50">
        <% if (!kesehatan.length) { %><tr><td colspan="4" class="px-5 py-6 text-center text-forest-400">Belum ada catatan kesehatan.</td></tr><% } %>
        <% kesehatan.forEach(k => { %>
          <tr>
            <td class="px-5 py-2 text-forest-600"><%= k.tanggal %></td>
            <td class="px-5 py-2 font-medium <%= k.jenis === 'Kematian' ? 'text-clay-600' : 'text-wheat-600' %>"><%= k.jenis %></td>
            <td class="px-5 py-2"><%= k.jumlah %> ekor</td>
            <td class="px-5 py-2 text-forest-400"><%= k.catatan || '-' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <!-- Riwayat Produksi -->
  <div class="bg-white rounded-2xl border border-black/5 shadow-sm overflow-hidden">
    <div class="px-5 py-3 border-b border-forest-50 flex items-center justify-between">
      <h3 class="font-display font-bold text-forest-900 text-sm">Riwayat Produksi Telur</h3>
      <a href="/produksi/tambah" class="text-xs font-semibold text-forest-600 hover:text-forest-900">+ Catat Produksi</a>
    </div>
    <table class="w-full text-sm">
      <thead class="bg-forest-50 text-forest-600 text-xs uppercase">
        <tr><th class="text-left px-5 py-2">Tanggal</th><th class="text-left px-5 py-2">Jumlah</th><th class="text-left px-5 py-2">Berat (kg)</th><th class="text-left px-5 py-2">Grade A/B/C</th><th class="text-left px-5 py-2">Terjual</th></tr>
      </thead>
      <tbody class="divide-y divide-forest-50">
        <% if (!produksi.length) { %><tr><td colspan="5" class="px-5 py-6 text-center text-forest-400">Belum ada data produksi untuk batch ini.</td></tr><% } %>
        <% produksi.forEach(p => { %>
          <tr>
            <td class="px-5 py-2 text-forest-600"><%= p.tanggal %></td>
            <td class="px-5 py-2 font-semibold text-forest-900"><%= p.jumlah_butir %></td>
            <td class="px-5 py-2 text-forest-600"><%= p.berat_kg %></td>
            <td class="px-5 py-2 text-forest-600"><%= p.grade_a %>/<%= p.grade_b %>/<%= p.grade_c %></td>
            <td class="px-5 py-2 text-forest-600"><%= p.terjual || 0 %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
