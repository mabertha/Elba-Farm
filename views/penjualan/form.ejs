<div class="max-w-lg bg-white rounded-2xl border border-black/5 shadow-sm p-6">
  <p class="text-xs text-forest-500 mb-4">Stok telur tersedia: <span class="font-bold text-forest-900"><%= stokTersedia %> butir</span></p>
  <form action="/penjualan" method="POST" class="space-y-4">
    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="block text-xs font-semibold text-forest-700 mb-1">Tanggal</label>
        <input name="tanggal" type="date" required value="<%= new Date().toISOString().slice(0,10) %>" class="w-full px-4 py-2.5 rounded-lg border border-forest-200 focus:outline-none focus:ring-2 focus:ring-forest-500">
      </div>
      <div>
        <label class="block text-xs font-semibold text-forest-700 mb-1">Nama Pelanggan</label>
        <input name="pelanggan" required class="w-full px-4 py-2.5 rounded-lg border border-forest-200 focus:outline-none focus:ring-2 focus:ring-forest-500">
      </div>
    </div>
    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="block text-xs font-semibold text-forest-700 mb-1">Jumlah (butir)</label>
        <input name="jumlah_butir" type="number" min="1" max="<%= stokTersedia %>" required class="w-full px-4 py-2.5 rounded-lg border border-forest-200 focus:outline-none focus:ring-2 focus:ring-forest-500">
      </div>
      <div>
        <label class="block text-xs font-semibold text-forest-700 mb-1">Harga per Butir (Rp)</label>
        <input name="harga_per_butir" type="number" min="0" required class="w-full px-4 py-2.5 rounded-lg border border-forest-200 focus:outline-none focus:ring-2 focus:ring-forest-500">
      </div>
    </div>
    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="block text-xs font-semibold text-forest-700 mb-1">Metode Pembayaran</label>
        <select name="metode_pembayaran" class="w-full px-4 py-2.5 rounded-lg border border-forest-200 focus:outline-none focus:ring-2 focus:ring-forest-500">
          <option>Tunai</option><option>Transfer</option><option>QRIS</option>
        </select>
      </div>
      <div>
        <label class="block text-xs font-semibold text-forest-700 mb-1">Status Pembayaran</label>
        <select name="status_pembayaran" class="w-full px-4 py-2.5 rounded-lg border border-forest-200 focus:outline-none focus:ring-2 focus:ring-forest-500">
          <option value="lunas">Lunas</option><option value="belum_lunas">Belum Lunas</option>
        </select>
      </div>
    </div>
    <div class="flex gap-3 pt-2">
      <button class="bg-forest-700 hover:bg-forest-800 text-white font-semibold px-5 py-2.5 rounded-lg transition text-sm">Simpan</button>
      <a href="/penjualan" class="text-forest-500 text-sm font-semibold px-5 py-2.5">Batal</a>
    </div>
  </form>
</div>
