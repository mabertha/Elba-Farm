<div class="space-y-4">
  <div class="flex justify-between items-center">
    <div class="bg-white rounded-xl px-4 py-2 border border-black/5 text-sm">
      <span class="text-forest-400">Stok telur tersedia:</span> <span class="font-bold text-forest-900"><%= stokTersedia %> butir</span>
    </div>
    <a href="/penjualan/tambah" class="bg-forest-700 hover:bg-forest-800 text-white text-sm font-semibold px-4 py-2 rounded-lg transition">+ Catat Penjualan</a>
  </div>

  <div class="bg-white rounded-2xl border border-black/5 shadow-sm overflow-x-auto">
    <table class="w-full text-sm">
      <thead class="bg-forest-50 text-forest-600 text-xs uppercase">
        <tr>
          <th class="text-left px-5 py-3">Tanggal</th><th class="text-left px-5 py-3">Pelanggan</th>
          <th class="text-left px-5 py-3">Jumlah</th><th class="text-left px-5 py-3">Harga/Butir</th>
          <th class="text-left px-5 py-3">Total</th><th class="text-left px-5 py-3">Status</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-forest-50">
        <% if (!penjualan.length) { %><tr><td colspan="6" class="px-5 py-8 text-center text-forest-400">Belum ada penjualan.</td></tr><% } %>
        <% penjualan.forEach(p => { %>
          <tr>
            <td class="px-5 py-3 text-forest-600"><%= p.tanggal %></td>
            <td class="px-5 py-3 font-medium"><%= p.pelanggan %></td>
            <td class="px-5 py-3"><%= p.jumlah_butir %></td>
            <td class="px-5 py-3 text-forest-600">Rp <%= p.harga_per_butir.toLocaleString('id-ID') %></td>
            <td class="px-5 py-3 font-semibold text-forest-900">Rp <%= p.total.toLocaleString('id-ID') %></td>
            <td class="px-5 py-3">
              <span class="text-xs font-semibold px-2 py-0.5 rounded-full <%= p.status_pembayaran === 'lunas' ? 'bg-forest-50 text-forest-600' : 'bg-wheat-100 text-wheat-600' %>"><%= p.status_pembayaran %></span>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
