<div class="max-w-lg bg-white rounded-2xl border border-black/5 shadow-sm p-6">
  <form action="<%= kandang ? '/kandang/' + kandang.id + '?_method=PUT' : '/kandang' %>" method="POST" class="space-y-4">
    <div>
      <label class="block text-xs font-semibold text-forest-700 mb-1">Nama Kandang</label>
      <input name="nama" required value="<%= kandang ? kandang.nama : '' %>" class="w-full px-4 py-2.5 rounded-lg border border-forest-200 focus:outline-none focus:ring-2 focus:ring-forest-500" placeholder="Kandang Elba 2">
    </div>
    <div>
      <label class="block text-xs font-semibold text-forest-700 mb-1">Kapasitas (ekor)</label>
      <input name="kapasitas" type="number" min="1" required value="<%= kandang ? kandang.kapasitas : '' %>" class="w-full px-4 py-2.5 rounded-lg border border-forest-200 focus:outline-none focus:ring-2 focus:ring-forest-500">
    </div>
    <div>
      <label class="block text-xs font-semibold text-forest-700 mb-1">Lokasi</label>
      <input name="lokasi" value="<%= kandang ? kandang.lokasi : '' %>" class="w-full px-4 py-2.5 rounded-lg border border-forest-200 focus:outline-none focus:ring-2 focus:ring-forest-500" placeholder="Rumah - Sidoarjo">
    </div>
    <div>
      <label class="block text-xs font-semibold text-forest-700 mb-1">Kondisi</label>
      <select name="kondisi" class="w-full px-4 py-2.5 rounded-lg border border-forest-200 focus:outline-none focus:ring-2 focus:ring-forest-500">
        <% ['Baik','Perlu Perbaikan','Perbaikan Berjalan'].forEach(opt => { %>
          <option <%= kandang && kandang.kondisi === opt ? 'selected' : '' %>><%= opt %></option>
        <% }) %>
      </select>
    </div>
    <div class="flex gap-3 pt-2">
      <button class="bg-forest-700 hover:bg-forest-800 text-white font-semibold px-5 py-2.5 rounded-lg transition text-sm">Simpan</button>
      <a href="/kandang" class="text-forest-500 text-sm font-semibold px-5 py-2.5">Batal</a>
    </div>
  </form>
</div>
