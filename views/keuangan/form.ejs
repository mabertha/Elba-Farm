<div class="max-w-lg bg-white rounded-2xl border border-black/5 shadow-sm p-6">
  <form action="/keuangan" method="POST" class="space-y-4">
    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="block text-xs font-semibold text-forest-700 mb-1">Jenis</label>
        <select name="jenis" class="w-full px-4 py-2.5 rounded-lg border border-forest-200 focus:outline-none focus:ring-2 focus:ring-forest-500">
          <option value="pemasukan">Pemasukan</option>
          <option value="pengeluaran">Pengeluaran</option>
        </select>
      </div>
      <div>
        <label class="block text-xs font-semibold text-forest-700 mb-1">Tanggal</label>
        <input name="tanggal" type="date" required value="<%= new Date().toISOString().slice(0,10) %>" class="w-full px-4 py-2.5 rounded-lg border border-forest-200 focus:outline-none focus:ring-2 focus:ring-forest-500">
      </div>
    </div>
    <div>
      <label class="block text-xs font-semibold text-forest-700 mb-1">Kategori</label>
      <input name="kategori" required placeholder="cth: Gaji Pegawai, Listrik, Penjualan Ayam Afkir" class="w-full px-4 py-2.5 rounded-lg border border-forest-200 focus:outline-none focus:ring-2 focus:ring-forest-500">
    </div>
    <div>
      <label class="block text-xs font-semibold text-forest-700 mb-1">Deskripsi</label>
      <input name="deskripsi" class="w-full px-4 py-2.5 rounded-lg border border-forest-200 focus:outline-none focus:ring-2 focus:ring-forest-500">
    </div>
    <div>
      <label class="block text-xs font-semibold text-forest-700 mb-1">Jumlah (Rp)</label>
      <input name="jumlah" type="number" min="0" required class="w-full px-4 py-2.5 rounded-lg border border-forest-200 focus:outline-none focus:ring-2 focus:ring-forest-500">
    </div>
    <div class="flex gap-3 pt-2">
      <button class="bg-forest-700 hover:bg-forest-800 text-white font-semibold px-5 py-2.5 rounded-lg transition text-sm">Simpan</button>
      <a href="/keuangan" class="text-forest-500 text-sm font-semibold px-5 py-2.5">Batal</a>
    </div>
  </form>
</div>
