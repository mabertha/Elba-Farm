<div class="max-w-lg bg-white rounded-2xl border border-black/5 shadow-sm p-6">
  <form action="/pakan" method="POST" class="space-y-4">
    <div>
      <label class="block text-xs font-semibold text-forest-700 mb-1">Nama Pakan</label>
      <input name="nama" required class="w-full px-4 py-2.5 rounded-lg border border-forest-200 focus:outline-none focus:ring-2 focus:ring-forest-500" placeholder="Konsentrat Layer">
    </div>
    <div>
      <label class="block text-xs font-semibold text-forest-700 mb-1">Supplier</label>
      <input name="supplier" class="w-full px-4 py-2.5 rounded-lg border border-forest-200 focus:outline-none focus:ring-2 focus:ring-forest-500">
    </div>
    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="block text-xs font-semibold text-forest-700 mb-1">Stok Awal</label>
        <input name="stok" type="number" step="0.1" min="0" required class="w-full px-4 py-2.5 rounded-lg border border-forest-200 focus:outline-none focus:ring-2 focus:ring-forest-500">
      </div>
      <div>
        <label class="block text-xs font-semibold text-forest-700 mb-1">Satuan</label>
        <select name="satuan" class="w-full px-4 py-2.5 rounded-lg border border-forest-200 focus:outline-none focus:ring-2 focus:ring-forest-500">
          <option value="kg">kg</option><option value="sak">sak</option><option value="liter">liter</option>
        </select>
      </div>
    </div>
    <div>
      <label class="block text-xs font-semibold text-forest-700 mb-1">Harga per Satuan (Rp)</label>
      <input name="harga_per_satuan" type="number" min="0" class="w-full px-4 py-2.5 rounded-lg border border-forest-200 focus:outline-none focus:ring-2 focus:ring-forest-500">
    </div>
    <div class="flex gap-3 pt-2">
      <button class="bg-forest-700 hover:bg-forest-800 text-white font-semibold px-5 py-2.5 rounded-lg transition text-sm">Simpan</button>
      <a href="/pakan" class="text-forest-500 text-sm font-semibold px-5 py-2.5">Batal</a>
    </div>
  </form>
</div>
